// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  balance       Float     @default(0)
  holdBalance   Float     @default(0) // Số dư đang bị tạm giữ (escrow)
  role          String    @default("BUYER") // BUYER, SELLER, ADMIN
  telegramId    String?
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  level         Int       @default(0)
  totalRevenue  Float     @default(0)
  isActive      Boolean   @default(true)
  avatar        String?
  fullName      String?
  phone         String?
  bankAccount   String?
  bankName      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  products      Product[]
  buyerOrders   Order[]   @relation("BuyerOrders")
  sellerOrders  Order[]   @relation("SellerOrders")
  transactions  Transaction[]
  affiliateLinks AffiliateLink[]
  chatRooms     ChatParticipant[]
  chatLogs      ChatLog[]
  coupons       Coupon[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String?
  parentId    String?
  parent      Category? @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id          String    @id @default(cuid())
  sellerId    String
  seller      User      @relation(fields: [sellerId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  title       String
  slug        String    @unique
  description String
  type        String    // DIGITAL, SERVICE
  price       Float
  priceMax    Float?    // for range pricing
  thumbnail   String?
  status      String    @default("PENDING") // PENDING, ACTIVE, PAUSED, REJECTED
  isFeatured  Boolean   @default(false)
  isSponsored Boolean   @default(false)
  viewCount   Int       @default(0)
  soldCount   Int       @default(0)
  rating      Float     @default(0)
  warrantyDays Int      @default(3) // 3 days for digital, 7 for service
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items       ProductItem[]
  variants    ProductVariant[]
  orders      Order[]
  reviews     Review[]
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  name        String    // e.g. "Gmail 2009-2015 (Cổ)"
  price       Float
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  items       ProductItem[]
}

model ProductItem {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  variantId   String?   // optional: links to ProductVariant
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  content     String    // the actual digital content (key, account, etc.)
  isSold      Boolean   @default(false)
  soldAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Order {
  id              String    @id @default(cuid())
  buyerId         String
  buyer           User      @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId        String
  seller          User      @relation("SellerOrders", fields: [sellerId], references: [id])
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  variantName     String?   // Tên biến thể đã mua (vd: Kênh Bật Kiếm Tiền)
  quantity        Int       @default(1)
  amount          Float
  fee             Float     @default(0)
  status          String    @default("PENDING") // PENDING, HOLDING, COMPLETED, DISPUTED, REFUNDED
  deliveredContent String?
  warrantyExpire  DateTime?
  couponCode      String?
  discountAmount  Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dispute         Dispute?
  review          Review?
}

model Dispute {
  id            String    @id @default(cuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id])
  reason        String
  evidence      String?             // Items lỗi buyer paste vào
  faultyCount   Int       @default(0) // Số items lỗi
  status        String    @default("OPEN") // OPEN, REFUNDED, WARRANTY, ESCALATED, RESOLVED, CLOSED
  resolution    String?             // REFUND, WARRANTY, DISPUTE
  sellerReply   String?
  adminDecision String?
  refundAmount  Float     @default(0)
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  messages      DisputeMessage[]
}

model DisputeMessage {
  id          String    @id @default(cuid())
  disputeId   String
  dispute     Dispute   @relation(fields: [disputeId], references: [id])
  senderId    String
  senderRole  String    // BUYER, SELLER, ADMIN
  message     String
  createdAt   DateTime  @default(now())
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  amount      Float
  type        String    // DEPOSIT, WITHDRAW, PURCHASE, REFUND, FEE
  status      String    @default("PENDING") // PENDING, SUCCESS, FAILED
  gatewayRef  String?
  description String?
  createdAt   DateTime  @default(now())
}

model Review {
  id        String    @id @default(cuid())
  orderId   String    @unique
  order     Order     @relation(fields: [orderId], references: [id])
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  rating    Int       // 1-5
  comment   String?
  createdAt DateTime  @default(now())
}

model Coupon {
  id            String    @id @default(cuid())
  sellerId      String
  seller        User      @relation(fields: [sellerId], references: [id])
  code          String    @unique
  discountType  String    // PERCENT, FIXED
  discountValue Float
  usageLimit    Int?
  usageCount    Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model AffiliateLink {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  code            String    @unique
  commissionRate  Float     @default(5)
  totalEarned     Float     @default(0)
  clickCount      Int       @default(0)
  createdAt       DateTime  @default(now())
}

model ChatLog {
  id            String    @id @default(cuid())
  sessionId     String
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  message       String
  aiResponse    String
  contextSummary String?
  createdAt     DateTime  @default(now())
}

model Banner {
  id          String    @id @default(cuid())
  imageUrl    String
  linkUrl     String?
  title       String?
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Announcement {
  id        String    @id @default(cuid())
  message   String
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
}

// Admin system settings (single row, key-value)
model SystemConfig {
  id                  String  @id @default("default")
  maxBoothsPerSeller  Int     @default(10)   // Giới hạn gian hàng mỗi seller
  maxItemsPerOrder    Int     @default(50)   // Giới hạn items mỗi đơn
  commissionRate      Float   @default(5)    // % hoa hồng sàn
  minWithdrawAmount   Float   @default(50000)
  maintenanceMode     Boolean @default(false)
  updatedAt           DateTime @updatedAt
}

// Per-user overrides for limits
model UserOverride {
  id                  String  @id @default(cuid())
  userId              String  @unique
  maxBooths           Int?    // null = dùng mặc định
  maxItemsPerOrder    Int?
  commissionRate      Float?  // custom commission
  note                String? // admin ghi chú
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ChatRoom {
  id            String        @id @default(cuid())
  isGroup       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  participants  ChatParticipant[]
  messages      ChatMessage[]
}

model ChatParticipant {
  id         String   @id @default(cuid())
  roomId     String
  userId     String   // Liên kết với User.id (hoặc 'SYSTEM_BOT')
  lastRead   DateTime @default(now())
  joinedAt   DateTime @default(now())
  
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(cuid())
  roomId     String
  senderId   String   // Liên kết với User.id (hoặc 'SYSTEM_BOT')
  content    String
  createdAt  DateTime @default(now())
  isSystem   Boolean  @default(false) // Đánh dấu tin nhắn hệ thống
  
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}
